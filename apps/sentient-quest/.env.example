###############################################################################
# SENTIENTQUEST ENVIRONMENT CONFIGURATION EXAMPLE
#
# This file serves as a blueprint for configuring the SentientQuest game
# environment. Copy this to .env.local for local development.
#
# LAST MODIFIED: 2026-04-26T16:55:06Z
# TIMESTAMP: 2026-04-26T16:55:06Z
###############################################################################

# --- AI & LLM CONFIGURATION ---
# The core agentic logic requires an LLM provider.
# Supported providers: OpenAI, Anthropic, Gemini, Perchance (Internal)
NEXT_PUBLIC_LLM_PROVIDER=perchance

# API Key for the chosen provider.
# REQUIRED if using external providers.
LLM_API_KEY=your_api_key_here

# The model identifier to use (e.g., gpt-4-turbo, claude-3-opus).
LLM_MODEL=sentient-v1-logic

# --- GAMEPLAY & SIMULATION ---
# Difficulty level for the initial genesis sequence.
# Options: Baseline, Challenging, Paradoxical, Reality-Bending
NEXT_PUBLIC_INITIAL_TIER=Baseline

# Duration (in milliseconds) for the physics update loop.
# Lower values increase accuracy but may impact performance.
PHYSICS_TICK_RATE=16.67

# --- TELEMETRY & LOGGING ---
# Secret hash for administrative access to the Architect Telemetry Stream.
# DO NOT share this in production.
ADMIN_PASSWORD_HASH=c41071b42945d910edf078201c3cb0e6bdbf77e02c994293b5c724f99b7489ec

# Channel ID for global telemetry sync.
TELEMETRY_CHANNEL=animus-telemetry-log

# --- DEPLOYMENT & NETWORKING ---
# The base URL for the hosted game. Used for cross-origin link generation.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

###############################################################################
# EDGE CASES & TROUBLESHOOTING
# 1. If LLM responses are slow, ensure PHYSICS_TICK_RATE is not competing for CPU.
# 2. If telemetry fails, verify that your browser doesn't block cross-site scripts.
# 3. For Perchance-specific plugins, check documentation at perchance.org.
###############################################################################

/* Last Modified: 2026-04-26T17:07:24Z | Timestamp: 2026-04-26T17:07:24Z */
